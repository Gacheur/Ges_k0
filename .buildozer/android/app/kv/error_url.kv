MDFloatLayout:

	Image:
		pos_hint: {'center_y': .8, 'center_x': .5}
		size_hint: (None, None)
		size : "200dp", "200dp"
		source: "static/logo.png"

	MDLabel:
		text:"Bienvenue !"
		pos_hint: {'center_y': .5}
		font_style: "H4"
		halign:"center"

	MDLabel:
		text:"Veuillez renseinger l'adresse du serveur"
		pos_hint: {'center_y': .4}
		halign:"center"


	MDTextField:
		id:server_adress
		pos_hint:{'center_y':.3, 'center_x': .5}
		size_hint_x:.6
		hint_text: "Adresse du serveur"
		on_focus: self.icon_right = ''


	MDFloatingActionButton:
		pos_hint:{'center_y':.2, 'center_x': .5}
		icon: "check"
		on_press: app.set_serveur_adress()



	MDLabel:
		text:"Be excellent to each other"
		pos_hint: {'center_y': .1}
		halign:"center"
		color: (100,100,100,1)